# Terraform state — never commit
*.tfstate
*.tfstate.backup
.terraform/

# Lock file intentionally tracked to pin provider versions across machines.
# After running `terraform init`, commit the generated .terraform.lock.hcl.

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Sensitive var files — use SOPS-encrypted versions instead
*.auto.tfvars
secrets.tfvars
