# Copy this file to secrets.yml and fill in your real values.
# secrets.yml is gitignored — never commit it.
#
# Optionally encrypt with ansible-vault:
#   ansible-vault encrypt secrets.yml
# Then run playbooks with:
#   ansible-playbook site.yml --ask-vault-pass
#   (or set ANSIBLE_VAULT_PASSWORD_FILE)

---
# Virtual IP for the k3s API server (must be unused on your subnet)
apiserver_endpoint: "192.168.100.10"

# MetalLB LoadBalancer IP range (must be within your subnet, not used by DHCP)
metal_lb_ip_range: "192.168.100.100-192.168.100.200"

# Shared secret for k3s cluster communication — alphanumeric only
# Generate a strong random value: openssl rand -hex 32
k3s_token: "REPLACE_WITH_STRONG_RANDOM_TOKEN"
